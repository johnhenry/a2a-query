{
  "name": "@johnhenry/a2aq",
  "version": "0.1.0-rc.3",
  "description": "Reactive, cached, embeddable A2A client for non-agentic apps — agent-card registry, task-handle store, approval broker. TanStack-Query-style, on the official @a2a-js/sdk.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnhenry/a2a-query.git"
  },
  "homepage": "https://github.com/johnhenry/a2a-query",
  "bugs": "https://github.com/johnhenry/a2a-query/issues",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "a2aq-codegen": "dist/codegen/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/mockAgent.d.ts",
      "default": "./dist/testing/mockAgent.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "example:01": "tsx examples/01-hello-task.ts",
    "example:02": "tsx examples/02-live-status.ts",
    "example:03": "tsx examples/03-approval-inbox.ts",
    "example:04": "tsx examples/04-manual-resume.ts",
    "example:05": "tsx examples/05-multi-agent.ts",
    "example:06": "tsx examples/06-policy-autopilot.ts",
    "example:07": "tsx examples/07-devtools-and-resilience.ts",
    "example:08": "tsx examples/08-streaming.ts",
    "example:09": "tsx examples/09-artifact-store.ts",
    "example:10": "tsx examples/10-wire-log.ts",
    "example:11": "tsx examples/11-skill-codegen.ts",
    "example:12": "tsx examples/12-push-webhook.ts"
  },
  "dependencies": {
    "@johnhenry/agent-query-core": "0.1.0-rc.3"
  },
  "peerDependencies": {
    "@a2a-js/sdk": "1.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@a2a-js/sdk": "1.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "happy-dom": "^20.11.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
